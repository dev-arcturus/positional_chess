# Server-specific ignores (the root .gitignore covers most of these too;
# duplicating here keeps the server folder portable on its own).

# Dependencies
node_modules/

# Environment & secrets
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# Runtime
pids/
*.pid
*.seed

# Coverage
coverage/
.nyc_output/

# OS noise
.DS_Store

# Local engine artifacts
engine.log
*.nnue.tmp

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
